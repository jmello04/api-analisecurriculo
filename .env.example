# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_DB=resume_analyzer

DATABASE_URL=postgresql://postgres:your-strong-password-here@localhost:5432/resume_analyzer

# ── Analysis Service ──────────────────────────────────────────────────────────
ANALYSIS_API_KEY=your-api-key-here
ANALYSIS_MODEL=your-model-name-here

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10
